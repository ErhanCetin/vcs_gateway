# =============================================================================
# VCS Gateway — Environment Variables Template
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — NEVER commit real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Service Identity
# -----------------------------------------------------------------------------
SERVICE_NAME=vcs-gateway
ENVIRONMENT=local               # local | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARN | ERROR
PORT=8001

# -----------------------------------------------------------------------------
# Database (asyncpg DSN format)
# Format: postgresql://user:password@host:port/dbname
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/vcs_gateway_db
DATABASE_SCHEMA=vcs_gateway_schema
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_COMMAND_TIMEOUT=30

# -----------------------------------------------------------------------------
# RabbitMQ (AMQP)
# Format: amqp://user:password@host:port/vhost
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://appuser:apppassword@localhost:5672/
RABBITMQ_PREFETCH_COUNT=10

# Exchanges / Queues
RABBITMQ_EXCHANGE_WEBHOOK=vcs.webhook.received    # Outbox publishes here
RABBITMQ_EXCHANGE_JOURNEY=journey.events           # Fire-and-forget journey events

# -----------------------------------------------------------------------------
# Redis
# Format: redis://host:port/db
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX=20
REDIS_IDEMPOTENCY_TTL_SECONDS=259200   # 72 hours

# -----------------------------------------------------------------------------
# Outbox Publisher
# -----------------------------------------------------------------------------
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_BATCH_SIZE=50

# -----------------------------------------------------------------------------
# Webhook Validation
# -----------------------------------------------------------------------------
# Tenant webhook secrets are stored per-tenant in the DB.
# These are global fallback / admin secrets.
WEBHOOK_HMAC_ALGORITHM=sha256
WEBHOOK_REQUEST_TIMEOUT_SECONDS=5
